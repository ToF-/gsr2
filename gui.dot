digraph gui {
    fontname="Helvetica,Arial,sans-serif"
 node [fontname="Helvetica,Arial,sans-serif"]
 edge [fontname="Helvetica,Arial,sans-serif"]
    gui -> application_window;
    gui -> single_view_scrolled_window;
    gui -> multiple_view_scrolled_window;
    gui -> multiple_view_grid;
    gui -> view_stack;
    gui -> single_view_box;
    gui -> single_view_picture;
    single_view_scrolled_window -> single_view_box;
    multiple_view_scrolled_window -> multiple_view_panel;
    multiple_view_panel -> left_button;
    multiple_view_panel -> multiple_view_grid;
    multiple_view_panel -> right_button;
    left_button -> left_gesture_click;
    right_button -> right_gesture_click;
    view_stack -> single_view_scrolled_window;
    view_stack -> multiple_view_scrolled_window;
    application_window -> view_stack;
    multiple_view_grid -> cell_box_00;
    multiple_view_grid -> cell_box_…;
    multiple_view_grid -> cell_box_99;
    single_view_box -> drawing_area;
    
    cell_box_… -> picture_…;
    cell_box_… -> label_…;
    cell_box_… -> left_gesture_click_…;
    cell_box_… -> right_gesture_click_…;


    single_view_box -> single_view_picture;
    application_window -> event_controller_key
}
    

